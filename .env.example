# ── Database ──────────────────────────────────────────────────────────
POSTGRES_PASSWORD=postgres
POSTGRES_DB=agentrec
AGENTREC_DATABASE_URL=postgresql://postgres:postgres@db:5432/agentrec

# ── Redis ─────────────────────────────────────────────────────────────
AGENTREC_REDIS_URL=redis://redis:6379/0

# ── Model & Data ─────────────────────────────────────────────────────
AGENTREC_MODEL_PATH=/app/models/checkpoints/ncf_best.pt
AGENTREC_DATA_DIR=/app/data
AGENTREC_MOVIELENS_VARIANT=small

# ── API Server ────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=info

# ── Port mapping (host ports) ────────────────────────────────────────
DB_PORT=5432
REDIS_PORT=6379
